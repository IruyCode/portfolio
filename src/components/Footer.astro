---
const { t } = Astro.props;
---

<footer class="bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4 py-12">
        <!-- Grade principal (3 colunas no desktop, centralizado no mobile) -->
        <div class="grid md:grid-cols-3 gap-8 text-center md:text-left">
            <!-- Sobre -->
            <div class="space-y-4">
                <h3 class="text-xl font-bold">{t.footer.about}</h3>
                <p class="text-gray-400">{t.footer.aboutText}</p>
            </div>

            <!-- Links Rápidos -->
            <div class="space-y-4">
                <h3 class="text-xl font-bold">{t.footer.quickLinks}</h3>
                <ul class="space-y-2">
                    <li>
                        <a href="#home" class="text-gray-400 hover:text-white"
                            >{t.footer.links.home}</a
                        >
                    </li>
                    <li>
                        <a href="#about" class="text-gray-400 hover:text-white"
                            >{t.footer.links.about}</a
                        >
                    </li>
                    <li>
                        <a
                            href="#projects"
                            class="text-gray-400 hover:text-white"
                            >{t.footer.links.projects}</a
                        >
                    </li>
                    <li>
                        <a href="#works" class="text-gray-400 hover:text-white"
                            >{t.footer.links.works}</a
                        >
                    </li>
                    <li>
                        <a
                            href="#contact"
                            class="text-gray-400 hover:text-white"
                            >{t.footer.links.contact}</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Serviços -->
            <div class="space-y-4">
                <h3 class="text-xl font-bold">{t.footer.services}</h3>
                <ul class="space-y-2">
                    {
                        t.footer.servicesList.map((service) => (
                            <li class="text-gray-400">{service}</li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Linha divisória inferior -->
    <div class="border-t border-gray-800 mt-8">
        <div class="max-w-7xl mx-auto px-4 py-6">
            <div class="flex flex-col items-center text-center gap-2">
                <p class="text-gray-400">
                    &copy; 2025 Portfolio. {t.footer.copyright}
                </p>
            </div>
        </div>
    </div>
</footer>
